<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LÚMINASCZ | Salud Digital UAGRM</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Inter', sans-serif; background: #e0f2fe; }
    </style>
</head>
<body>

    <nav class="bg-white/80 p-4 shadow-sm flex items-center justify-between">
        <div class="flex items-center space-x-2">
            <div class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center text-white font-bold">L</div>
            <span class="text-2xl font-bold text-blue-900">LÚMINASCZ</span>
        </div>
    </nav>

    <header class="py-16 px-4 text-center">
        <div class="flex justify-center space-x-6 mb-12">
            <div class="w-24 h-24 bg-white rounded-full border-4 border-blue-200 shadow-xl flex items-center justify-center text-xs text-blue-900 font-bold p-4">Medicina</div>
            <div class="w-24 h-24 bg-white rounded-full border-4 border-blue-200 shadow-xl flex items-center justify-center text-xs text-blue-900 font-bold p-4">UAGRM</div>
            <div class="w-24 h-24 bg-white rounded-full border-4 border-blue-200 shadow-xl flex items-center justify-center text-xs text-blue-900 font-bold p-4">Salud</div>
        </div>

        <h1 class="text-6xl font-extrabold text-blue-900 mb-6">LÚMINA</h1>
        <p class="text-xl text-gray-700 italic mb-12 max-w-2xl mx-auto">"Tu Salud, Nuestro Compromiso. Consultas médicas gratuitas y seguras para estudiantes de la UAGRM"</p>

        <a href="#registro" class="inline-block px-12 py-4 border-2 border-green-900 text-green-900 font-bold text-lg hover:bg-green-900 hover:text-white transition-all shadow-lg rounded-md">
            AGENDA TU CITA AHORA
        </a>
    </header>

    <section id="registro" class="max-w-xl mx-auto p-8 bg-white rounded-xl shadow-lg mb-16">
        <h2 class="text-3xl font-bold text-blue-900 mb-6 text-center">Agendar Cita</h2>
        <form id="citaForm" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700">ID del Paciente</label>
                <input type="number" name="pacienteId" required class="w-full p-3 border border-gray-300 rounded-md">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">ID del Médico</label>
                <input type="number" name="medicoId" required class="w-full p-3 border border-gray-300 rounded-md">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">Fecha y Hora</label>
                <input type="datetime-local" name="fechaHora" required class="w-full p-3 border border-gray-300 rounded-md">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">Motivo de la consulta</label>
                <textarea name="motivo" required class="w-full p-3 border border-gray-300 rounded-md"></textarea>
            </div>
            <button type="submit" class="w-full bg-blue-600 text-white py-3 rounded-md font-bold hover:bg-blue-700 transition-all">
                CONFIRMAR CITA
            </button>
        </form>
        <div id="responseMessage" class="mt-4 text-center font-bold hidden"></div>
    </section>

    <script>
        document.getElementById('citaForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const form = e.target;
            const responseMessage = document.getElementById('responseMessage');
            
            const formData = {
                pacienteId: parseInt(form.pacienteId.value),
                medicoId: parseInt(form.medicoId.value),
                fechaHora: form.fechaHora.value,
                motivo: form.motivo.value
            };

            try {
                // Esto intentará enviar la cita a tu backend
                const response = await fetch('https://tu-backend-url.onrender.com/api/citas', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });

                responseMessage.classList.remove('hidden');
                if (response.ok) {
                    responseMessage.innerText = "¡Cita creada con éxito!";
                    responseMessage.classList.add('text-green-600');
                    form.reset();
                } else {
                    responseMessage.innerText = "Error al agendar. Verifica los IDs.";
                    responseMessage.classList.add('text-red-600');
                }
            } catch (err) {
                responseMessage.classList.remove('hidden');
                responseMessage.innerText = "
